{% do attrs.set(
  class="
    w-full
    rounded-lg
    p-2.5
    text-sm
    font-medium
    leading-5
    [&:not([data-selected],[data-disabled])]:text-blue-100

    [&:not([data-selected],[data-disabled])]:hover:bg-white/10
    [&:not([data-selected],[data-disabled])]:hover:text-white

    focus:outline-none
    focus:ring-2
    focus:ring-offset-2
    focus:ring-opacity-50
    focus:ring-blue-500
    [&:not([data-selected],[data-disabled])]:focus-visible:bg-white/10
    [&:not([data-selected],[data-disabled])]:focus-visible:text-white

    [&[data-selected]]:text-blue-700
    [&[data-selected]]:bg-white
    [&[data-selected]]:shadow
  "
) %}

<Tab __attrs={attrs}>{{ content }}</Tab>
