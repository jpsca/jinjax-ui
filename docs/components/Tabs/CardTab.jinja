{% do attrs.set(
  class="
    w-full
    rounded-lg
    p-2.5
    text-sm
    font-medium
    leading-5
    [&:not(.ui-selected,.ui-disabled)]:text-blue-100

    [&:not(.ui-selected,.ui-disabled)]:hover:bg-white/10
    [&:not(.ui-selected,.ui-disabled)]:hover:text-white

    focus:outline-none
    focus:ring-2
    focus:ring-offset-2
    focus:ring-opacity-50
    focus:ring-blue-500
    [&:not(.ui-selected,.ui-disabled)]:focus-visible:bg-white/10
    [&:not(.ui-selected,.ui-disabled)]:focus-visible:text-white

    [&.ui-selected]:text-blue-700
    [&.ui-selected]:bg-white
    [&.ui-selected]:shadow
  "
) %}

<Tab __attrs={attrs}>{{ content }}</Tab>
