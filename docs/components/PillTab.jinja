{% do attrs.set(
  class="
    w-full
    rounded-lg
    text-sm
    leading-5
    [&:not(.ui-selected,.ui-disabled)]:text-blue-100

    [&:not(.ui-selected,.ui-disabled)]:hover:bg-black/10
    [&:not(.ui-selected,.ui-disabled)]:hover:text-white

    focus:outline-none
    focus:ring-2
    focus:ring-offset-2
    focus:ring-opacity-50
    focus:ring-blue-500

    [&.ui-selected]:text-blue-700
    [&.ui-selected]:bg-white
    [&.ui-selected]:shadow
  "
) %}

<Tab :__attrs="attrs">{{ content }}</Tab>
