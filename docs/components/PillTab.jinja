{% do attrs.set(
  class="
    w-full
    rounded-lg
    py-2.5
    text-sm
    font-medium
    leading-5
    [&:not(.selected,[disabled])]:text-blue-100

    [&:not(.selected,[disabled])]:hover:bg-white/10
    [&:not(.selected,[disabled])]:hover:text-white

    focus:outline-none
    focus:ring-2
    focus:ring-offset-2
    focus:ring-opacity-50
    focus:ring-blue-500
    [&:not(.selected,[disabled])]:focus-visible:bg-white/10
    [&:not(.selected,[disabled])]:focus-visible:text-white

    [&.selected]:text-blue-700
    [&.selected]:bg-white
    [&.selected]:shadow
  "
) %}

<Tab __attrs={attrs}>{{ content }}</Tab>
