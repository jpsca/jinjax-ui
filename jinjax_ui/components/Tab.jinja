{#def target, selected=False, tag="button" #}

{%- if tag == "button" -%}
    {% do attrs.setdefault(type="button") %}
{%- endif -%}

<{{ tag }} {{ attrs.render(
    data_tab=true,
    class="selected" if selected else "",
    role="tab",
    aria_selected="true" if selected else "false",
    aria_controls=target,
    tabindex="0" if selected else "-1",
) }}>{{ content }}</{{ tag }}>
