{#def selected=false, disabled=false, tag="a" #}

{% do attrs.add_class("ui-menu-item") %}
{% if disabled -%}
  {% do attrs.add_class("ui-disabled") %}
{%- endif %}
{% if selected and not disabled -%}
  {% do attrs.add_class("ui-selected") %}
{%- endif %}

<{{ tag }} {{ attrs.render(
  role="menuitem",
  tabindex="-1",
) }}>{{ content }}</{{ tag }}>
